  <script>
  function toggleNav() {
    const navOv = document.getElementById('navOverlay');
    const menuTgl = document.getElementById('menuToggle');
    if (!navOv || !menuTgl) return;
    const isOpen = navOv.classList.toggle('open');
    navOv.setAttribute('aria-hidden', !isOpen);
    menuTgl.classList.toggle('open', isOpen);
  }
  function closeNav() {
    const navOv = document.getElementById('navOverlay');
    const menuTgl = document.getElementById('menuToggle');
    if (!navOv) return;
    navOv.classList.remove('open');
    navOv.setAttribute('aria-hidden', 'true');
    if (menuTgl) menuTgl.classList.remove('open');
  }
  document.addEventListener('DOMContentLoaded', function() {
    var closeBtn = document.getElementById('navClose');
    if (closeBtn) closeBtn.addEventListener('click', closeNav);
    var navOv = document.getElementById('navOverlay');
    if (navOv) {
      navOv.addEventListener('click', function(e) { if (e.target === navOv) closeNav(); });
    }
    document.querySelectorAll('.ace-item').forEach(function(item) {
      item.addEventListener('mouseenter', function() { this.classList.add('hov'); });
      item.addEventListener('mouseleave', function() { this.classList.remove('hov'); });
    });
  });
  </script>

  <script>
  (function() {
    function ready(fn) {
      if (document.readyState !== 'loading') fn();
      else document.addEventListener('DOMContentLoaded', fn);
    }

    function escapeHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    /* ===== SLAT BUTTON BUILDER ===== */
    function makeSlatButton(text, href, tagName, size) {
      var chars = text.split('').map(function(ch) {
        var safe = ch === ' ' ? '\u00A0' : escapeHtml(ch);
        return '<span class="slat-char">' + safe + '<span class="slat-char-bg">' + safe + '</span></span>';
      }).join('');
      var sizeClass = size ? ' ' + size : '';
      if (tagName === 'a') {
        return '<a href="' + (href || '#') + '" class="hover-slat-btn' + sizeClass + '"><span class="group">' + chars + '</span></a>';
      }
      return '<button type="button" class="hover-slat-btn' + sizeClass + '"><span class="group">' + chars + '</span></button>';
    }

    function getActivityMeta() {
      var params = new URLSearchParams(window.location.search);
      var data = window.platformData;
      if (!data) return {};
      var axis = data.axes.find(function(a) { return a.id === params.get('axe'); });
      var objective = axis && axis.objectives.find(function(o) { return o.id === params.get('objectif'); });
      var activity = objective && objective.activities.find(function(a) { return a.number === Number(params.get('activite')); });
      return { axis: axis, objective: objective, activity: activity, moduleType: (activity && activity.moduleType) || '' };
    }

    /* ===== STANDARD BUTTON BUILDER ===== */
    function makeStandardButton(text, href, tagName, classes) {
      var cls = 'btn-standard';
      if (classes) {
        cls += ' ' + classes.replace('hover-slat-btn', '').trim();
      }
      if (tagName === 'a') {
        return '<a href="' + (href || '#') + '" class="' + cls + '">' + escapeHtml(text) + '</a>';
      }
      return '<button type="button" class="' + cls + '">' + escapeHtml(text) + '</button>';
    }

    /* ===== SLATIFY ONLY LAST BUTTON IN EACH GROUP ===== */
    function slatifyButtons() {
      // Process action-rows: only slatify the last button
      document.querySelectorAll('.action-row').forEach(function(row) {
        var buttons = row.querySelectorAll('.btn, button[type="button"], input[type="button"], .activity-nav-link');
        if (buttons.length === 0) return;
        
        buttons.forEach(function(btn, index) {
          if (btn.classList.contains('hover-slat-btn') || btn.closest('.hover-slat-btn')) return;
          if (btn.classList.contains('zen-timeline-nav')) return;
          if (btn.id === 'menuToggle') return;
          if (btn.id === 'navClose') return;
          
          var text = (btn.textContent || btn.value || '').trim();
          if (!text) return;

          var isLast = index === buttons.length - 1;
          var tagName = btn.tagName.toLowerCase();
          var href = btn.getAttribute('href') || '#';
          var onclick = btn.getAttribute('onclick');
          var id = btn.id;
          var className = btn.className;

          var newBtn;
          if (isLast) {
            // Slatify the last button
            var size = '';
            if (btn.id === 'saveButton' || btn.classList.contains('btn-lg')) {
              size = 'slat-lg';
            } else if (btn.classList.contains('btn-sm') || text.length < 6) {
              size = 'slat-sm';
            }
            var slatHtml = makeSlatButton(text, href, tagName === 'a' ? 'a' : 'button', size);
            var temp = document.createElement('div');
            temp.innerHTML = slatHtml;
            newBtn = temp.firstChild;
          } else {
            // Standard button for others
            var stdHtml = makeStandardButton(text, href, tagName, className);
            var temp = document.createElement('div');
            temp.innerHTML = stdHtml;
            newBtn = temp.firstChild;
          }

          if (id) newBtn.id = id;
          if (onclick) newBtn.setAttribute('onclick', onclick);
          
          // Copy data attributes
          Array.from(btn.attributes).forEach(function(attr) {
            if (attr.name.startsWith('data-')) {
              newBtn.setAttribute(attr.name, attr.value);
            }
          });

          btn.parentNode.replaceChild(newBtn, btn);
        });
      });

      // Process pager: only slatify the last link/button
      var pager = document.getElementById('activityPager');
      if (pager) {
        var pagerButtons = pager.querySelectorAll('.btn, button[type="button"], input[type="button"], .activity-nav-link, a');
        pagerButtons.forEach(function(btn, index) {
          if (btn.classList.contains('hover-slat-btn') || btn.closest('.hover-slat-btn')) return;
          
          var text = (btn.textContent || btn.value || '').trim();
          if (!text) return;

          var isLast = index === pagerButtons.length - 1;
          var tagName = btn.tagName.toLowerCase();
          var href = btn.getAttribute('href') || '#';
          var onclick = btn.getAttribute('onclick');
          var id = btn.id;
          var className = btn.className;

          var newBtn;
          if (isLast) {
            var size = text.length > 15 ? '' : 'slat-sm';
            var slatHtml = makeSlatButton(text, href, tagName === 'a' ? 'a' : 'button', size);
            var temp = document.createElement('div');
            temp.innerHTML = slatHtml;
            newBtn = temp.firstChild;
          } else {
            var stdHtml = makeStandardButton(text, href, tagName, className);
            var temp = document.createElement('div');
            temp.innerHTML = stdHtml;
            newBtn = temp.firstChild;
          }

          if (id) newBtn.id = id;
          if (onclick) newBtn.setAttribute('onclick', onclick);
          
          Array.from(btn.attributes).forEach(function(attr) {
            if (attr.name.startsWith('data-')) {
              newBtn.setAttribute(attr.name, attr.value);
            }
          });

          btn.parentNode.replaceChild(newBtn, btn);
        });
      }
    }

    /* ===== HERO ENHANCEMENT ===== */
    function enhanceHero(meta) {
      var hero = document.getElementById('activityHero');
      if (!hero) return;

      // Add axis image to the right
      var axisImages = {
        'axe-1': 'axe 1 image.png',
        'axe-2': 'axe 2 image.png',
        'axe-3': 'axe 3 image.png',
        'axe-4': 'axe 4 image.png'
      };
      var axisId = meta.axis && meta.axis.id;
      if (axisId && axisImages[axisId]) {
        var img = document.createElement('img');
        img.className = 'zen-hero-image';
        img.src = axisImages[axisId];
        img.alt = meta.axis.name || 'Axe';
        if (!hero.querySelector('.zen-hero-image')) {
          hero.appendChild(img);
        }
      }

      // Add watermark logo
      if (!hero.querySelector('.zen-hero-logo')) {
        var logo = document.createElement('img');
        logo.className = 'zen-hero-logo';
        logo.src = 'zenclasse solo logo.png';
        logo.alt = '';
        hero.appendChild(logo);
      }

      // Style subtitle pills
      var subtitle = hero.querySelector('.hero-subtitle');
      if (subtitle) {
        var parts = subtitle.textContent.split('·').map(function(s){ return s.trim(); }).filter(Boolean);
        if (parts.length > 1) {
          subtitle.innerHTML = parts.map(function(p){ return '<span class="hero-pill">' + escapeHtml(p) + '</span>'; }).join('');
        }
      }

      // Style badge
      var badge = hero.querySelector('.activity-head p');
      if (badge) badge.classList.add('zen-hero-badge');
    }

    /* ===== TIMELINE SELECTOR ===== */
    function setupTimeline(meta) {
      var timeline = document.getElementById('activityTimeline');
      var content = document.getElementById('activityContent');
      if (!timeline || !content) return;

      var type = meta.moduleType;
      var moduleRoot = content.querySelector('.activity-module');

      if (!moduleRoot) {
        timeline.style.display = 'none';
        return;
      }

      // Determine steps
      var steps = [];
      var stepLabels = [];

      if (type === 'verbatim') {
        setupVerbatimTimeline(timeline, content, meta);
        return;
      }

      // For modules with clear sections
      var sections = Array.from(moduleRoot.children).filter(function(el) {
        return (el.tagName === 'SECTION' || el.classList.contains('module-section')) && !el.hasAttribute('hidden');
      });

      if (sections.length > 1) {
        steps = sections;
        stepLabels = sections.map(function(s, i) {
          var heading = s.querySelector('h2, h3, .module-title, .section-title');
          return heading ? heading.textContent.trim() : 'Étape ' + (i + 1);
        });
      } else {
        // Create artificial steps for simple modules
        var allChildren = Array.from(moduleRoot.children).filter(function(el) {
          return !el.hasAttribute('hidden') && el.tagName !== 'STYLE';
        });
        
        if (allChildren.length === 0) {
          timeline.style.display = 'none';
          return;
        }

        // Split into 3-4 steps
        var stepCount = Math.min(4, Math.max(3, Math.ceil(allChildren.length / 2)));
        var chunkSize = Math.ceil(allChildren.length / stepCount);
        
        for (var i = 0; i < stepCount; i++) {
          var wrapper = document.createElement('div');
          wrapper.className = 'zen-step-content';
          var chunk = allChildren.slice(i * chunkSize, (i + 1) * chunkSize);
          chunk.forEach(function(c) { wrapper.appendChild(c); });
          moduleRoot.appendChild(wrapper);
          steps.push(wrapper);
          
          // Try to find a label from first heading
          var firstHeading = wrapper.querySelector('h2, h3, .module-title, .section-title, p');
          if (firstHeading) {
            stepLabels.push(firstHeading.textContent.trim().substring(0, 30));
          } else {
            stepLabels.push('Étape ' + (i + 1));
          }
        }
      }

      if (steps.length <= 1) {
        timeline.style.display = 'none';
        return;
      }

      timeline.classList.add('is-visible');
      buildTimeline(timeline, steps, stepLabels, 0);
      showStep(steps, 0);
    }

    function buildTimeline(container, steps, labels, current) {
      var total = steps.length;
      var dotsHtml = steps.map(function(s, i) {
        var isActive = i === current ? 'is-active' : (i < current ? 'is-completed' : '');
        return '<div class="zen-timeline-step ' + isActive + '" data-step="' + i + '">' +
          '<div class="zen-timeline-dot">' + (i + 1) + '</div>' +
          '<div class="zen-timeline-label">' + escapeHtml(labels[i] || ('Étape ' + (i + 1))) + '</div>' +
          '</div>';
      }).join('');

      container.innerHTML =
        '<div class="zen-timeline">' +
        '<button class="zen-timeline-nav" data-dir="prev" ' + (current === 0 ? 'disabled' : '') + '>‹</button>' +
        '<div class="zen-timeline-track">' + dotsHtml + '</div>' +
        '<button class="zen-timeline-nav" data-dir="next" ' + (current === total - 1 ? 'disabled' : '') + '>›</button>' +
        '</div>';

      // Event delegation
      container.addEventListener('click', function(e) {
        var stepEl = e.target.closest('.zen-timeline-step');
        var navEl = e.target.closest('.zen-timeline-nav');
        
        if (stepEl) {
          var idx = parseInt(stepEl.getAttribute('data-step'), 10);
          showStep(steps, idx);
          buildTimeline(container, steps, labels, idx);
        } else if (navEl) {
          var dir = navEl.getAttribute('data-dir');
          var newIdx = dir === 'prev' ? current - 1 : current + 1;
          if (newIdx >= 0 && newIdx < total) {
            showStep(steps, newIdx);
            buildTimeline(container, steps, labels, newIdx);
          }
        }
      });
    }

    function showStep(steps, index) {
      steps.forEach(function(s, i) {
        s.classList.toggle('is-active', i === index);
      });
    }

    function setupVerbatimTimeline(timeline, content, meta) {
      var counter = document.getElementById('verbatimExerciseCounter');
      if (!counter) {
        timeline.style.display = 'none';
        return;
      }

      function parseTotal() {
        var m = counter.textContent.match(/\/\s*(\d+)/);
        return m ? parseInt(m[1], 10) : 4;
      }

      var total = parseTotal();
      var steps = [];
      var labels = [];
      
      for (var i = 0; i < total; i++) {
        labels.push('Exercice ' + (i + 1));
      }

      // Create placeholder steps for verbatim (content managed by module)
      var moduleRoot = content.querySelector('.activity-module');
      if (moduleRoot) {
        for (var j = 0; j < total; j++) {
          var wrapper = document.createElement('div');
          wrapper.className = 'zen-step-content';
          wrapper.setAttribute('data-verbatim-step', j);
          moduleRoot.appendChild(wrapper);
          steps.push(wrapper);
        }
      }

      if (steps.length <= 1) {
        timeline.style.display = 'none';
        return;
      }

      timeline.classList.add('is-visible');
      buildTimeline(timeline, steps, labels, 0);
      showStep(steps, 0);

      // Sync with verbatim counter
      var observer = new MutationObserver(function() {
        var m = counter.textContent.match(/(\d+)\s*\//);
        var current = m ? parseInt(m[1], 10) - 1 : 0;
        showStep(steps, current);
        buildTimeline(timeline, steps, labels, current);
      });
      observer.observe(counter, { childList: true, subtree: true, characterData: true });
    }

    /* ===== PAGER TRANSFORM ===== */
    function transformPager() {
      // Pager buttons are now handled by slatifyButtons()
      // This function is kept for backward compatibility
      var pager = document.getElementById('activityPager');
      if (!pager) return;
      
      // Only process links that haven't been processed yet
      pager.querySelectorAll('a:not(.hover-slat-btn):not(.btn-standard)').forEach(function(link, index, all) {
        var text = link.textContent.trim();
        var href = link.getAttribute('href') || '#';
        var isLast = index === all.length - 1;
        
        if (isLast) {
          var size = text.length > 15 ? '' : 'slat-sm';
          link.outerHTML = makeSlatButton(text, href, 'a', size);
        } else {
          link.classList.add('btn-standard');
        }
      });
    }

    /* ===== MAIN INIT ===== */
    ready(function() {
      var meta = getActivityMeta();
      if (meta.moduleType) {
        document.body.classList.add('zen-module-' + meta.moduleType);
      }
      enhanceHero(meta);
      
      // Wait for module to render
      setTimeout(function() {
        setupTimeline(meta);
        slatifyButtons();
        transformPager();
      }, 100);

      // Watch for dynamically added content
      var contentObserver = new MutationObserver(function() {
        slatifyButtons();
        transformPager();
      });
      var contentEl = document.getElementById('activityContent');
      if (contentEl) {
        contentObserver.observe(contentEl, { childList: true, subtree: true });
      }
    });
  })();
  </script>
</body>
</html>
